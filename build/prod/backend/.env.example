BACKEND_HOST=0.0.0.0
BACKEND_PORT=8010

APP_DOMAIN={{domain}}
APP_GLOBAL_SALT={{global_salt}}
APP_BCRYPT_ROUNDS=12
APP_ENVIRONMENT=prod

POSTGRES_HOST=cobalt-postgres
POSTGRES_PORT=5432
POSTGRES_USER=cobalt
POSTGRES_PASSWORD={{postgres_password}}
POSTGRES_DB=cobalt_prod

REDIS_HOST=cobalt-redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD={{redis_password}}

PROMETHEUS_HOST=cobalt-prometheus
PROMETHEUS_PORT=9090
