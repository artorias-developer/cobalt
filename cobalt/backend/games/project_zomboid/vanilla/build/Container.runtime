FROM debian:bookworm-slim

ARG SERVER_ROOT

RUN apt-get update && \
    apt-get install -y software-properties-common && \
    dpkg --add-architecture i386 && \
    apt-add-repository non-free && \
    apt-get update && \
    apt-get install -y \
        bash && \
    rm -rf /var/lib/apt/lists/*

WORKDIR ${SERVER_ROOT}

ENTRYPOINT ["/bin/bash", "-c", "exec ./entrypoint.sh"]