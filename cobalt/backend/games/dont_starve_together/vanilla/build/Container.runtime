FROM debian:bookworm-slim

ARG SERVER_ROOT

RUN dpkg --add-architecture i386 && \
    apt-get update && \
    apt-get install -y \
        bash \
        lib32gcc-s1 \
        lib32stdc++6 \
        libgcc-s1 \
        libcurl4-gnutls-dev:i386 && \
    rm -rf /var/lib/apt/lists/*

WORKDIR ${SERVER_ROOT}

ENTRYPOINT ["/bin/bash", "-c", "exec ./entrypoint.sh"]